# Copy to your shell profile or export before release scripts.

# Code signing identity from Keychain Access.
# Example: Developer ID Application: Your Name (TEAMID)
export APPLE_CODESIGN_IDENTITY="Developer ID Application: YOUR NAME (TEAMID)"

# Option A (recommended): use a stored notarytool profile.
# Create once:
# xcrun notarytool store-credentials "local-stereo-transcriber" \
#   --apple-id "name@example.com" \
#   --team-id "TEAMID" \
#   --password "app-specific-password"
export NOTARYTOOL_PROFILE="local-stereo-transcriber"

# Option B: direct credentials (only if not using profile)
# export APPLE_ID="name@example.com"
# export APPLE_TEAM_ID="TEAMID"
# export APPLE_APP_PASSWORD="app-specific-password"
